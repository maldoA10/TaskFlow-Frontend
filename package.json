{
  "name": "taskflow-frontend",
  "version": "1.0.0",
  "description": "TaskFlow PWA - Frontend colaborativo offline-first",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maldoA10/TaskFlow-Frontend.git"
  },
  "keywords": [
    "task management",
    "pwa",
    "offline-first",
    "frontend"
  ],
  "author": "Andres Maldonado",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/maldoA10/TaskFlow-Frontend/issues"
  },
  "homepage": "https://github.com/maldoA10/TaskFlow-Frontend#readme",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "clsx": "^2.1.1",
    "idb": "^8.0.0",
    "lucide-react": "^0.487.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.2.4",
    "fake-indexeddb": "^6.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "webpack": "^5.106.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
